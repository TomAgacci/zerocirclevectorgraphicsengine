python3 -c "import math;P=lambda t,x,y,u:(math.sin(math.atan2(y,x)+u[0]*t)+math.sin(2*math.atan2(y,x)+u[1]*t+math.hypot(x,y))+math.sin(3*math.atan2(y,x)+u[2]*t+math.hypot(x,y)**2));x,y=0.5,0.5;t=1;u=(1,2,3);r=math.hypot(x,y)+0.2*P(t,x,y,u);a=math.atan2(y,x);print((r*math.cos(a),r*math.sin(a),0.5*P(t,x,y,u)))"
