// PluginProcessor.cpp
#include "PluginProcessor.h"
#include "PluginEditor.h"

RamanujanAudioProcessor::RamanujanAudioProcessor()
: AudioProcessor(BusesProperties().withOutput("Output", juce::AudioChannelSet::stereo(), true)) {
    engine.reset(RamanujanSynthEngine::create());
}

RamanujanAudioProcessor::~RamanujanAudioProcessor() {}

bool RamanujanAudioProcessor::isBusesLayoutSupported(const BusesLayout& layouts) const {
    return layouts.getMainOutputChannelSet() == juce::AudioChannelSet::stereo();
}

void RamanujanAudioProcessor::prepareToPlay(double sampleRate, int samplesPerBlock) {
    if (engine) {
        engine->setSampleRate(sampleRate);
        engine->setBlockSize(samplesPerBlock);
    }
}

void RamanujanAudioProcessor::processBlock(juce::AudioBuffer<float>& buffer,
                                           juce::MidiBuffer& midi) {
    buffer.clear();

    if (!engine) return;

    for (const auto metadata : midi) {
        const auto msg = metadata.getMessage();
        if (msg.isNoteOn()) {
            engine->noteOn(msg.getNoteNumber(), msg.getFloatVelocity());
        } else if (msg.isNoteOff()) {
            engine->noteOff(msg.getNoteNumber());
        }
    }

    auto* left  = buffer.getWritePointer(0);
    auto* right = buffer.getNumChannels() > 1 ? buffer.getWritePointer(1) : nullptr;

    engine->process(left, right ? right : left, buffer.getNumSamples());
}
