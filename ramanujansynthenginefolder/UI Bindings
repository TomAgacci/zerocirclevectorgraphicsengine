class RamanujanAudioProcessor : public juce::AudioProcessor {
public:
    RamanujanAudioProcessor()
    :   AudioProcessor(BusesProperties().withOutput("Output", juce::AudioChannelSet::stereo(), true)),
        parameters(*this, nullptr, "PARAMS", createParameterLayout())
    {
        engine.reset(RamanujanSynthEngine::create());
    }

    static juce::AudioProcessorValueTreeState::ParameterLayout createParameterLayout() {
        using P = juce::AudioProcessorValueTreeState;

        std::vector<std::unique_ptr<juce::RangedAudioParameter>> params;

        params.push_back(std::make_unique<juce::AudioParameterFloat>(
            "masterGain", "Master Gain", 0.0f, 1.0f, 0.8f));

        params.push_back(std::make_unique<juce::AudioParameterFloat>(
            "fountainLevel", "Fountain Level", 0.0f, 1.0f, 0.7f));

        params.push_back(std::make_unique<juce::AudioParameterFloat>(
            "npcNoiseLevel", "NPC Noise Level", 0.0f, 1.0f, 0.5f));

        params.push_back(std::make_unique<juce::AudioParameterBool>(
            "seqEnable", "Sequencer Enable", true));

        params.push_back(std::make_unique<juce::AudioParameterFloat>(
            "bpm", "BPM", 40.0f, 300.0f, 100.0f));

        params.push_back(std::make_unique<juce::AudioParameterInt>(
            "harmonyMode", "Harmony Mode", 0, 7, 0));

        return { params.begin(), params.end() };
    }

    juce::AudioProcessorValueTreeState parameters;
};
